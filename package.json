{
  "name": "auth-worker-nextauth",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js 15 + Express + PostgreSQL authentication scaffold with NextAuth",
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:express\"",
    "dev:next": "next dev",
    "dev:express": "tsx watch src/server.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:migrate": "drizzle-kit push:pg",
    "db:generate": "drizzle-kit generate:pg",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.0.0",
    "@playwright/experimental-ct-electron": "latest",
    "@playwright/test": "^1.48.0",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.0",
    "electron": "latest",
    "express": "^4.18.2",
    "lucide-react": "^0.460.0",
    "next": "15.0.0",
    "next-auth": "^5.0.0-beta.4",
    "node-mocks-http": "latest",
    "pg": "^8.11.3",
    "playwright": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-query": "latest",
    "uuid": "latest",
    "vite": "latest",
    "vite-plugin-electron": "latest",
    "vite-plugin-electron-renderer": "latest",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "autoprefixer": "^10.4.16",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "15.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@playwright/test": "^1.49.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
