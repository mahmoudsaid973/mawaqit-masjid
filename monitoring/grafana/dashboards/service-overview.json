{
  "title": "Mawaqit Masjid — Service overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Error rate (global, 5m)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(http_server_duration_seconds_count[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1
        }
      }
    },
    {
      "id": 2,
      "type": "graph",
      "title": "p95 latency (global, 5m)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_server_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "graph",
      "title": "Prayer Times — request rate + p95 latency",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_seconds_count{route=~\".*prayer-times.*\"}[5m]))",
          "refId": "A",
          "legendFormat": "rate"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_seconds_bucket{route=~\".*prayer-times.*\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ]
    },
