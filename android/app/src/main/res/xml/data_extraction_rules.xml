<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup rules. Exclude auth DataStore from cloud backup;
     include everything else in device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="auth.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <include domain="root"/>
    </device-transfer>
</data-extraction-rules>
